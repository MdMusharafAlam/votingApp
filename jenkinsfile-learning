pipeline {
    agent any

    environment {
        DOCKERHUB_USER = '8787490748'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Repository') {
            steps {
                bat 'dir'
            }
        }
        

// Paste the testing stage here
stage('Run Tests') {
    steps {

        dir('vote') {
            bat 'python -m pytest'
        }

        dir('result') {
            bat 'dotnet test'
        }

        dir('worker') {
            bat 'dotnet test'
        }

    }
}



        stage('Build Vote Image') {
            steps {
                bat 'docker build -t %DOCKERHUB_USER%/vote:v1 .\\vote'
            }
        }

        stage('Build Result Image') {
            steps {
                bat 'docker build -t %DOCKERHUB_USER%/result:v1 .\\result'
            }
        }

        stage('Build Worker Image') {
            steps {
                bat 'docker build -t %DOCKERHUB_USER%/worker:v1 .\\worker'
            }
        }

        stage('Build Seed Data Image') {
            steps {
                bat 'docker build -t %DOCKERHUB_USER%/seed-data:v1 .\\seed-data'
            }
        }

        stage('Verify Images') {
            steps {
                bat 'docker images'
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'voterapp_credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    bat 'docker login -u %DOCKER_USER% -p %DOCKER_PASS%'
                }
            }
        }

        stage('Push Images') {
            steps {
                bat 'docker push %DOCKERHUB_USER%/vote:v1'
                bat 'docker push %DOCKERHUB_USER%/result:v1'
                bat 'docker push %DOCKERHUB_USER%/worker:v1'
                bat 'docker push %DOCKERHUB_USER%/seed-data:v1'
            }
        }

        stage('Verify Docker Access') {
            steps {
                bat 'docker ps'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully and images pushed to Docker Hub!'
        }

        failure {
            echo 'Pipeline Failed!'
        }

        always {
            bat 'docker logout'
            echo 'Pipeline Execution Completed'
        }
    }
}