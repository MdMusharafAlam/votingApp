pipeline {
    agent any

    stages {

        stage('Build Images') {
            steps {
                bat 'docker compose build'
            }
        }

        stage('Start Containers') {
            steps {
                bat 'docker compose up -d'
            }
        }

        stage('Check Containers') {
            steps {
                bat 'docker ps'
            }
        }
    }

    post {
        success {
            echo 'Voting App deployed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}